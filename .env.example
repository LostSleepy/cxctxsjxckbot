# Discord Bot Token (required)
# Get it from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Groq API Key (required for AI chat commands)
# Get it from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Admin Discord User ID (the bot owner)
# The bot is already configured with a default, but you can override it here
# ADMIN_ID=979869404110159912

# Web server port (for keep-alive on free hosting)
# PORT=8080
